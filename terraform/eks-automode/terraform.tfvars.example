# EKS Auto Mode + Bedrock — Example values
# Copy this file to terraform.tfvars and fill in your values.

region       = "us-east-1"
cluster_name = "karo-cluster"

# Bedrock model
bedrock_model_id = "anthropic.claude-sonnet-4-20250514-v1:0"

# Agent credentials (optional — leave empty to skip secret creation)
github_token         = ""
mem0_api_key         = ""
slack_bot_token      = ""
slack_signing_secret = ""

# Set to true to deploy the example dev team
enable_example_agents = true

tags = {
  Project     = "karo"
  ManagedBy   = "opentofu"
  Environment = "dev"
}
