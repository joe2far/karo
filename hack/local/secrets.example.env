# hack/local/secrets.example.env
# Copy to hack/local/secrets.env and fill in real values, then:
#   set -a; source hack/local/secrets.env; set +a
#   hack/local/apply-dev-team.sh
#
# Only ANTHROPIC_API_KEY is needed for end-to-end agent calls.
# The rest can be left as placeholders for the first local run.

ANTHROPIC_API_KEY=sk-ant-...
GITHUB_TOKEN=ghp_...
MEM0_API_KEY=m0-...
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
